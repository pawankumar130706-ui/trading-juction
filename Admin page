<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Career Result Admin</title>

<style>
body{
font-family:Arial;
background:#f5f5f5;
margin:0;
}

.container{
max-width:700px;
margin:30px auto;
background:#fff;
padding:20px;
border-radius:8px;
box-shadow:0 0 10px rgba(0,0,0,.2);
}

h1{
text-align:center;
color:#b00000;
}

input,textarea,select{
width:100%;
padding:10px;
margin:10px 0;
}

button{
background:#b00000;
color:white;
border:none;
padding:12px;
width:100%;
font-size:18px;
cursor:pointer;
}

button:hover{
background:#870000;
}
</style>

</head>
<body>

<div class="container">

<h1>Career Result Admin Panel</h1>

<select>
<option>Latest Job</option>
<option>Result</option>
<option>Admit Card</option>
<option>Answer Key</option>
<option>Syllabus</option>
</select>

<input type="text" placeholder="Post Title">

<input type="text" placeholder="Official Website Link">

<input type="text" placeholder="Apply Online Link">

<input type="text" placeholder="Notification PDF Link">

<textarea rows="6" placeholder="Write Full Details"></textarea>

<button>Publish Post</button>

</div>

</body>
</html>
